pipeline {
    agent any
    environment {
        PROJECT_HOME = "${WORKSPACE}"
    }
    stages {
        stage('Run Application') {
            steps {
                echo 'Starting Flask application'
                script {
                    sh '''
                    echo "dummy log content" > ${PROJECT_HOME}/flask_app.log
                    cat ${PROJECT_HOME}/flask_app.log
                    '''
                 }
            }
        }
    stage('Archive Artifacts') {
        steps {
            dir("${PROJECT_HOME}") {
            archiveArtifacts artifacts: 'flask_app.log', allowEmptyArchive: true
                echo 'archiving flask_app.log'
        }
    }
}
    
        // Run this stage regardless of the user choice but we will check the user choice in the stage and print a message
        stage('Finalize the Pipeline') {
            steps {
                script {
                        echo 'Pipeline completed successfully'
                  
                    }
                }
            }
        }
    }
